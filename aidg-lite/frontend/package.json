{
  "name": "aidg-lite-ui",
  "version": "1.0.0",
  "type": "module",
  "description": "AIDG Lite UI — reusable React component library",
  "main": "./dist-lib/aidg-lite-ui.cjs.js",
  "module": "./dist-lib/aidg-lite-ui.es.js",
  "types": "./dist-lib/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist-lib/aidg-lite-ui.es.js",
      "require": "./dist-lib/aidg-lite-ui.cjs.js",
      "types": "./dist-lib/index.d.ts"
    },
    "./dist-lib/aidg-lite-ui.css": "./dist-lib/aidg-lite-ui.css"
  },
  "files": [
    "dist-lib"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "tsc -b --noEmit && vite build --config vite.lib.config.ts",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "@monaco-editor/react": ">=4",
    "antd": ">=5",
    "axios": ">=1",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@monaco-editor/react": ">=4",
    "@types/react-syntax-highlighter": "^15.5.13",
    "antd": ">=5",
    "axios": ">=1",
    "katex": "^0.16.9",
    "mermaid": "^11.12.0",
    "react": ">=18",
    "react-dom": ">=18",
    "react-markdown": "^9.0.1",
    "react-syntax-highlighter": "^15.6.6",
    "rehype-katex": "^7.0.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/react": "^18.2.22",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^4.2.0",
    "terser": "^5.44.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.0",
    "vite-plugin-dts": "^3.9.1"
  }
}
